# Skopiuj do .env i uzupełnij wartości

# Środowisko (production / development)
NODE_ENV=production

# Port serwera (Railway ustawia automatycznie)
PORT=3001

# Klucz sesji — ustaw losowy długi ciąg znaków!
SESSION_SECRET=zmien-mnie-na-losowy-ciag-znakow-min-32-znaki

# Ścieżka do katalogu z danymi (hotel.json + uploads)
# Na Railway ustaw to na ścieżkę wolumenu, np. /data
DATA_DIR=/data
